🚀 12. Plantilla universal
#include <stdio.h>

int main() {
    int n, num, suma = 0;

    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        scanf("%d", &num);
        suma += num;
    }

    printf("%d", suma);

    return 0;
}

